@model KlangIT_V3.ViewModels.ItemRepairViewModel
@{
    ViewData["Title"] = "บันทึกซ่อมแล้ว";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")
@await Html.PartialAsync("~/Views/Shared/_ItemStateDiagram.cshtml")

<h1 class="ds-page-title">บันทึกซ่อมแล้ว</h1>

<div class="ds-page-layout">

    @* ── Left: State diagram (emphasize ซ่อมแล้ว) ── *@
    <div>
        <div class="ds-diagram-wrap">
            <p class="ds-diagram-title">แผนผังการเปลี่ยนสถานะ</p>
            @await Html.PartialAsync("~/Views/Shared/_ItemStateDiagramSvgVertical.cshtml", "repair")
        </div>
    </div>

    @* ── Right: Repair form ── *@
    <div class="ds-card">
        @* Prominent banner *@
        <div style="display:flex;align-items:center;gap:20px;padding:20px;background:#E8F8F0;border:1px solid #B8E4CC;border-radius:var(--ds-radius-md);margin-bottom:1.25rem">
            <svg width="64" height="64" viewBox="0 0 64 64" fill="none" style="flex-shrink:0">
                <circle cx="32" cy="32" r="28" stroke="#1D9E75" stroke-width="3" fill="#F1FAF5"/>
                <path d="M20 32l8 8 16-16" stroke="#1D9E75" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
                <div style="font-size:36px;font-weight:800;color:#1D9E75;line-height:1">ซ่อมแล้ว</div>
                <div style="font-size:13px;color:var(--ds-text2);margin-top:4px">นำอุปกรณ์กลับมาอยู่ในสถานะ "พร้อมใช้งาน"</div>
            </div>
        </div>

        <span class="ds-section-lbl">รายละเอียดการซ่อม</span>
        <form asp-action="Repair" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

            <input type="hidden" asp-for="ItemId"/>

            <div class="ds-row">
                <label asp-for="ItemHeader" class="ds-lbl">ข้อมูลวัสดุ</label>
                <input asp-for="ItemHeader" class="ds-input ds-input-ro" readonly/>
            </div>

            <div class="ds-row">
                <label asp-for="ItemAssetId" class="ds-lbl">เลขทะเบียนทรัพย์สิน</label>
                <input asp-for="ItemAssetId" class="ds-input ds-input-ro" readonly
                       style="font-family:monospace;font-size:12px"/>
            </div>

            <div class="ds-row">
                <span class="ds-lbl">สถานะปัจจุบัน</span>
                <div style="padding:8px 12px;background:var(--ds-bg2);border-radius:var(--ds-radius-md)">
                    @{
                        string statusBadge = Model.ItemStatus == KlangIT_V3.Models.Enums.ItemStatusEnum.Damaged
                            ? "ds-badge ds-badge-red" : "ds-badge ds-badge-amber";
                    }
                    <span class="@statusBadge">@Html.DisplayFor(m => m.ItemStatus)</span>
                    <span style="margin-left:12px;font-size:13px;color:var(--ds-text2)">ชำรุดอยู่ @Model.DamagedAmount เครื่อง</span>
                </div>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <label asp-for="Amount" class="ds-lbl">จำนวนที่ซ่อมแล้ว</label>
                    <input asp-for="Amount" class="ds-input" type="number" min="1" max="@Model.DamagedAmount"/>
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
                <div class="ds-row">
                    <label asp-for="Itstaff" class="ds-lbl">ผู้ดำเนินการ (IT)</label>
                    <input asp-for="Itstaff" class="ds-input ds-input-ro" readonly/>
                    <span asp-validation-for="Itstaff" class="text-danger small"></span>
                </div>
            </div>

            <div class="ds-row">
                <label asp-for="Remarks" class="ds-lbl">หมายเหตุ / รายละเอียดการซ่อม</label>
                <input asp-for="Remarks" class="ds-input"/>
            </div>

            <div class="ds-actions">
                <button type="submit" class="ds-btn-primary">ยืนยันซ่อมแล้ว</button>
                <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.ItemId"
                   class="ds-btn-ghost">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
