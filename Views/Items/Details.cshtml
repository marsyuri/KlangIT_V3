@using KlangIT_V3.Helpers
@model KlangIT_V3.ViewModels.ItemDetailsViewModel
@{
    ViewData["Title"] = "รายละเอียดอุปกรณ์";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">รายละเอียดอุปกรณ์</h1>
<p class="ds-page-sub">ข้อมูลอุปกรณ์และประวัติการยืม-คืน</p>

<span class="ds-section-lbl">ข้อมูลอุปกรณ์</span>
<div class="ds-card" style="max-width:640px;margin-bottom:1.5rem">
    <div class="ds-field-grid">
        <span class="ds-field-label">เลขทะเบียน</span>
        <span class="ds-field-value" style="font-family:monospace;font-size:12px">@Model.AssetId</span>

        <span class="ds-field-label">ประเภท</span>
        <span class="ds-field-value">@Model.ItemType?.Name</span>

        <span class="ds-field-label">ยี่ห้อ</span>
        <span class="ds-field-value">@Model.ItemBrand?.Name</span>

        <span class="ds-field-label">รุ่น</span>
        <span class="ds-field-value">@Model.ItemModel?.Name</span>

        <span class="ds-field-label">Serial Number</span>
        <span class="ds-field-value">@Model.SerialNo</span>

        <span class="ds-field-label">จำนวนทั้งหมด</span>
        <span class="ds-field-value">@Model.TotalAmount</span>

        <span class="ds-field-label">พร้อมใช้งาน</span>
        <span class="ds-field-value">
            @{
                string avlBadge = Model.AvailableAmount == 0 ? "ds-badge ds-badge-red"
                                : Model.AvailableAmount <= 2  ? "ds-badge ds-badge-amber"
                                : "ds-badge ds-badge-teal";
            }
            <span class="@avlBadge">@Model.AvailableAmount เครื่อง</span>
        </span>

        <span class="ds-field-label">กำลังยืม</span>
        <span class="ds-field-value">@Model.BorrowedAmount เครื่อง</span>

        <span class="ds-field-label">ชำรุด</span>
        <span class="ds-field-value">@Model.DamagedAmount เครื่อง</span>

        <span class="ds-field-label">สถานะ</span>
        <span class="ds-field-value">@Html.DisplayFor(m => m.ItemStatus)</span>

        <span class="ds-field-label">หมายเหตุ</span>
        <span class="ds-field-value" style="font-weight:400">@Model.Remarks</span>

        <span class="ds-field-label">แก้ไขล่าสุด</span>
        <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.ModifiedDate.ToString("dd MMM yyyy HH:mm")</span>

        <span class="ds-field-label">แก้ไขโดย</span>
        <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.ModifiedBy</span>
    </div>
</div>

@{
    var canBorrow = Model.AvailableAmount > 0;
}
<div class="mt-3">
    <a asp-controller="BorrowHistories"
           asp-action="Create"
           asp-route-itemId="@Model.Id"
           class="ds-btn-ghost @(canBorrow ? "" : "disabled")"
           aria-disabled="@(canBorrow ? "false" : "true")"
           tabindex="@(canBorrow ? "0" : "-1")">
        @(canBorrow ? "ทำการยืม" : "ถูกยืมแล้ว")
    </a>
</div>

<span class="ds-section-lbl">ประวัติการยืม-คืน</span>
<div class="ds-table-wrap" style="margin-bottom:1.5rem">
    <table class="ds-table">
        <thead>
            <tr>
                <th>#</th>
                <th>ผู้ยืม</th>
                <th>ฝ่าย / หน่วยงาน</th>
                <th>วันที่ยืม</th>
                <th>เจ้าหน้าที่ IT</th>
                <th>สถานะ</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.BHinItemDetails == null || !Model.BHinItemDetails.Any())
            {
                <tr><td colspan="7" class="ds-table-empty">ไม่มีประวัติการยืม-คืน</td></tr>
            }
            else
            {
                int i = 0;
                foreach (var bh in Model.BHinItemDetails)
                {
                    i++;
                    string badge = bh.IsReturn ? "ds-badge ds-badge-teal" : "ds-badge ds-badge-amber";
                    string label = bh.IsReturn ? "คืนแล้ว" : "กำลังยืม";
                    <tr>
                        <td style="color:var(--ds-text3)">@i</td>
                        <td>@bh.RequestUser</td>
                        <td style="color:var(--ds-text2)">@bh.RequestDepartment / @bh.RequestSection</td>
                        <td style="color:var(--ds-text2)">@bh.BorrowDate.ToString("dd MMM yyyy")</td>
                        <td style="color:var(--ds-text2)">@bh.LatestITStaff</td>
                        <td><span class="@badge">@label</span></td>
                        <td>
                            <div class="ds-tbl-actions">
                                @if (!bh.IsReturn)
                                {
                                    <a asp-controller="BorrowHistories" asp-action="Return"
                                       asp-route-id="@bh.Id" class="ds-btn-primary" style="font-size:12px;height:30px;padding:0 12px">
                                        บันทึกคืน
                                    </a>
                                }
                                <a asp-controller="BorrowHistories" asp-action="Delete"
                                   asp-route-id="@bh.Id" class="ds-btn-del-ghost" style="height:30px;padding:0 10px">ลบ</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<span class="ds-section-lbl">Timeline การเคลื่อนไหวของสต๊อก</span>
@{
    Func<int, Microsoft.AspNetCore.Html.IHtmlContent> delta = n =>
    {
        if (n == 0) return new Microsoft.AspNetCore.Html.HtmlString("<span style=\"color:var(--ds-text3)\">—</span>");
        string sign  = n > 0 ? "+" : "";
        string color = n > 0 ? "#1D9E75" : "#A32D2D";
        return new Microsoft.AspNetCore.Html.HtmlString($"<span style=\"color:{color};font-weight:500\">{sign}{n}</span>");
    };
}
<div class="ds-table-wrap" style="margin-bottom:1.5rem">
    <table class="ds-table" style="font-size:10.5px">
        <thead>
            <tr>
                <th rowspan="2">#</th>
                <th rowspan="2">วันที่/เวลา</th>
                <th rowspan="2">ประเภทรายการ</th>
                <th colspan="5" style="text-align:center;border-left:1px solid var(--ds-border)">การเปลี่ยนแปลง (Δ)</th>
                <th colspan="5" style="text-align:center;border-left:1px solid var(--ds-border)">คงเหลือหลังทำรายการ</th>
                <th rowspan="2" style="border-left:1px solid var(--ds-border)">ดำเนินการโดย</th>
            </tr>
            <tr>
                <th style="border-left:1px solid var(--ds-border)">พร้อมใช้</th>
                <th>ยืม</th>
                <th>ชำรุด</th>
                <th>จำหน่าย</th>
                <th>รวม</th>
                <th style="border-left:1px solid var(--ds-border)">พร้อมใช้</th>
                <th>ยืม</th>
                <th>ชำรุด</th>
                <th>จำหน่าย</th>
                <th>รวม</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.StockTimeline == null || !Model.StockTimeline.Any())
            {
                <tr><td colspan="14" class="ds-table-empty">ยังไม่มีรายการเคลื่อนไหว</td></tr>
            }
            else
            {
                int i = 0;
                foreach (var sl in Model.StockTimeline)
                {
                    i++;
                    <tr>
                        <td style="color:var(--ds-text3)">@i</td>
                        <td style="color:var(--ds-text2);white-space:nowrap">@sl.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td style="white-space:nowrap">@sl.LogType.GetDisplayName()</td>
                        <td style="font-family:monospace;text-align:right;border-left:1px solid var(--ds-border)">@delta(sl.DeltaAvailable)</td>
                        <td style="font-family:monospace;text-align:right">@delta(sl.DeltaBorrowed)</td>
                        <td style="font-family:monospace;text-align:right">@delta(sl.DeltaDamaged)</td>
                        <td style="font-family:monospace;text-align:right">@delta(sl.DeltaDisposed)</td>
                        <td style="font-family:monospace;text-align:right">@delta(sl.DeltaTotal)</td>
                        <td style="font-family:monospace;text-align:right;color:var(--ds-text2);border-left:1px solid var(--ds-border)">@sl.AvailableAfter</td>
                        <td style="font-family:monospace;text-align:right;color:var(--ds-text2)">@sl.BorrowedAfter</td>
                        <td style="font-family:monospace;text-align:right;color:var(--ds-text2)">@sl.DamagedAfter</td>
                        <td style="font-family:monospace;text-align:right;color:var(--ds-text2)">@sl.DisposedAfter</td>
                        <td style="font-family:monospace;text-align:right;color:var(--ds-text2);font-weight:500">@sl.TotalAfter</td>
                        <td style="color:var(--ds-text2);white-space:nowrap;border-left:1px solid var(--ds-border)">@sl.CreatedBy</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="ds-actions">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="ds-btn-primary">แก้ไข</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="ds-btn-del-ghost">ลบ</a>
    <a asp-action="Index" class="ds-btn-ghost">กลับรายการ</a>
</div>
