@model KlangIT_V3.ViewModels.ItemDeleteViewModel
@{
    ViewData["Title"] = "ลบอุปกรณ์";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">ลบอุปกรณ์</h1>
<p class="ds-page-sub">กรุณาตรวจสอบรายละเอียดก่อนดำเนินการลบ</p>

<div style="max-width:600px">
    <span class="ds-section-lbl">ข้อมูลอุปกรณ์</span>
    <div class="ds-card">
        <div class="ds-field-grid">
            <span class="ds-field-label">เลขทะเบียน</span>
            <span class="ds-field-value" style="font-family:monospace;font-size:12px">@Model.AssetId</span>

            <span class="ds-field-label">ประเภท</span>
            <span class="ds-field-value">@Model.ItemTypeName</span>

            <span class="ds-field-label">ยี่ห้อ / รุ่น</span>
            <span class="ds-field-value">@Model.ItemBrandName - @Model.ItemModelName</span>

            <span class="ds-field-label">สถานะ</span>
            <span class="ds-field-value">@Html.DisplayFor(m => m.ItemStatus)</span>

            <span class="ds-field-label">จำนวนพร้อมใช้</span>
            <span class="ds-field-value">@Model.AvailableAmount เครื่อง</span>
        </div>
    </div>

    @if (!Model.CanDelete)
    {
        <div class="ds-blocked-box">
            <div class="ds-blocked-title">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="7" stroke="#A32D2D" stroke-width="1.5"/>
                    <path d="M5 5L11 11M11 5L5 11" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                ไม่สามารถลบได้ - มีข้อมูลที่เกี่ยวข้องอยู่
            </div>
            <p class="ds-blocked-desc">
                อุปกรณ์นี้มีประวัติการยืม-คืน @Model.BorrowHistoryCount รายการ
                @if (Model.HasActiveBorrow)
                {
                    <strong> (มีรายการที่ยังไม่คืน)</strong>
                }
                - ต้องลบหรือคืนให้ครบก่อน
            </p>
            <div class="ds-dep-list">
                <div class="ds-dep-item">
                    <div>
                        <div class="ds-dep-name">ประวัติการยืม-คืน (BorrowHistory)</div>
                        <div class="ds-dep-count">@Model.BorrowHistoryCount รายการ</div>
                    </div>
                    <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.Id" class="ds-dep-link">ไปจัดการ →</a>
                </div>
            </div>
            <p class="ds-blocked-note">หากต้องการลบ กรุณาลบประวัติการยืม-คืนทั้งหมดก่อน</p>
        </div>

        <div class="ds-actions">
            <button class="ds-btn-danger" disabled>ยืนยันการลบ</button>
            <a asp-action="Index" class="ds-btn-ghost">ยกเลิก / กลับรายการ</a>
        </div>
    }
    else
    {
        <div class="ds-ok-row">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <circle cx="8" cy="8" r="7" stroke="#1D9E75" stroke-width="1.5"/>
                <path d="M5 8l2.5 2.5L11 5.5" stroke="#1D9E75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            ตรวจสอบแล้ว - ไม่มีประวัติการยืม-คืนที่เกี่ยวข้อง สามารถลบได้
        </div>

        <div class="ds-danger-box">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 2L16.5 15H1.5L9 2Z" stroke="#A32D2D" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M9 7V10" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="9" cy="13" r=".75" fill="#A32D2D"/>
            </svg>
            <div>
                <p class="ds-danger-title">การดำเนินการนี้ไม่สามารถย้อนกลับได้</p>
                <p class="ds-danger-desc">ข้อมูลอุปกรณ์นี้จะถูกลบออกจากระบบอย่างถาวร</p>
            </div>
        </div>

        <form asp-action="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id"/>
            <div class="ds-actions">
                <button type="submit" class="ds-btn-danger">ยืนยันการลบ</button>
                <a asp-action="Index" class="ds-btn-ghost">ยกเลิก / กลับรายการ</a>
            </div>
        </form>
    }
</div>
