@model KlangIT_V3.ViewModels.ItemEditViewModel
@{
    ViewData["Title"] = "แก้ไขวัสดุ";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<script>
    const typeToBrandsMap  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TypeToBrandsMap));
    const brandToTypesMap  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BrandToTypesMap));
    const brandToModelsMap = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BrandToModelsMap));
</script>

<h1 class="ds-page-title">แก้ไขวัสดุ</h1>

<div class="ds-card" style="max-width:560px">
    <form asp-action="Edit">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
        <input type="hidden" asp-for="Id"/>

        @* ── ข้อมูลทะเบียน ── *@
        <span class="ds-section-lbl">ข้อมูลทะเบียน</span>

        <div class="ds-row">
            <span class="ds-lbl">เลขครุภัณฑ์</span>
            <div class="ds-asset-row">
                <div style="display:flex;flex-direction:column;width:72px">
                    <input asp-for="AssetId1" class="ds-input" maxlength="4"/>
                    <span asp-validation-for="AssetId1" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;flex:1">
                    <input asp-for="AssetId2" class="ds-input" maxlength="8"/>
                    <span asp-validation-for="AssetId2" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;flex:1">
                    <input asp-for="AssetId3" class="ds-input" maxlength="8"/>
                    <span asp-validation-for="AssetId3" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;width:82px">
                    <input asp-for="AssetId4" class="ds-input" maxlength="5"/>
                    <span asp-validation-for="AssetId4" class="text-danger small"></span>
                </div>
            </div>
        </div>

        <div class="ds-row">
            <label asp-for="OtherAssetId" class="ds-lbl">เลขทะเบียนทรัพย์สินแบบอื่น</label>
            <input asp-for="OtherAssetId" class="ds-input"/>
        </div>

        <div class="ds-row">
            <label asp-for="SerialNo" class="ds-lbl">Serial Number</label>
            <input asp-for="SerialNo" class="ds-input"/>
        </div>

        <hr class="ds-divider"/>
        <span class="ds-section-lbl">ประเภท / ยี่ห้อ / รุ่น</span>

        <div class="ds-2col">
            <div class="ds-row">
                <label asp-for="SelectedItemTypeId" class="ds-lbl">ประเภทอุปกรณ์</label>
                <select asp-for="SelectedItemTypeId" id="ddlItemType" class="ds-select" asp-items="Model.ItemTypes"></select>
                <span asp-validation-for="SelectedItemTypeId" class="text-danger small"></span>
            </div>
            <div class="ds-row">
                <label asp-for="SelectedItemBrandId" class="ds-lbl">ยี่ห้อ</label>
                <select asp-for="SelectedItemBrandId" id="ddlItemBrand" class="ds-select" asp-items="Model.ItemBrands"></select>
                <span asp-validation-for="SelectedItemBrandId" class="text-danger small"></span>
            </div>
        </div>

        <div class="ds-row">
            <label asp-for="SelectedItemModelId" class="ds-lbl">รุ่น</label>
            <select asp-for="SelectedItemModelId" id="ddlItemModel" class="ds-select" asp-items="Model.ItemModels"></select>
            <span asp-validation-for="SelectedItemModelId" class="text-danger small"></span>
        </div>

        <div style="margin-top:-8px;margin-bottom:12px">
            <button type="button" class="ds-btn-ghost" id="btnClearCascade" style="font-size:12px;height:30px;padding:0 12px">
                ล้างประเภท/ยี่ห้อ/รุ่น
            </button>
        </div>

        <div class="ds-row">
            <label asp-for="ItemDescription" class="ds-lbl">รายละเอียดวัสดุ/อุปกรณ์</label>
            <input asp-for="ItemDescription" class="ds-input"/>
            <p class="ds-hint">ระบุรายละเอียดเพิ่มเติมของวัสดุ/อุปกรณ์ (เช่น สี, สเปก, จุดสังเกต)</p>
        </div>

        <div class="ds-row">
            <label asp-for="ItemImageUrl" class="ds-lbl">URL รูปภาพ</label>
            <input asp-for="ItemImageUrl" class="ds-input"/>
        </div>

        <hr class="ds-divider"/>
        <span class="ds-section-lbl">จำนวนและสถานะ</span>

        <div class="ds-3col">
            <div class="ds-row">
                <label asp-for="TotalAmount" class="ds-lbl">จำนวนทั้งหมด</label>
                <input asp-for="TotalAmount" class="ds-input" type="number" min="1"/>
                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
            </div>
            <div class="ds-row">
                <label asp-for="AvailableAmount" class="ds-lbl">พร้อมใช้งาน</label>
                <input asp-for="AvailableAmount" class="ds-input ds-input-ro" readonly/>
            </div>
            <div class="ds-row">
                <label asp-for="BorrowedAmount" class="ds-lbl">กำลังยืม</label>
                <input asp-for="BorrowedAmount" class="ds-input ds-input-ro" readonly/>
            </div>
        </div>

        <div class="ds-row" style="max-width:160px">
            <label asp-for="MinimumAmount" class="ds-lbl">จำนวนขั้นต่ำ</label>
            <input asp-for="MinimumAmount" class="ds-input" type="number" min="0"/>
            <span asp-validation-for="MinimumAmount" class="text-danger small"></span>
        </div>

        <div class="ds-row">
            <label asp-for="SelectedItemStatus" class="ds-lbl">สถานะของวัสดุ/ครุภัณฑ์</label>
            <div style="display:flex;align-items:center;gap:10px">
                <select asp-for="SelectedItemStatus" class="ds-select" style="width:auto;min-width:170px"
                        asp-items="Model.ItemStatuses" id="statusSelect"></select>
                <span class="ds-badge" id="statusBadge"></span>
            </div>
            <span asp-validation-for="SelectedItemStatus" class="text-danger small"></span>
        </div>

        <div class="ds-row">
            <label asp-for="Remarks" class="ds-lbl">หมายเหตุ</label>
            <input asp-for="Remarks" class="ds-input"/>
        </div>

        <hr class="ds-divider"/>
        <span class="ds-section-lbl">ข้อมูลระบบ</span>

        <div class="ds-2col">
            <div class="ds-row">
                <label asp-for="CreatedDate" class="ds-lbl">วันที่สร้าง</label>
                <input asp-for="CreatedDate" class="ds-input ds-input-ro" readonly/>
            </div>
            <div class="ds-row">
                <label asp-for="CreatedBy" class="ds-lbl">สร้างโดย</label>
                <input asp-for="CreatedBy" class="ds-input ds-input-ro" readonly/>
            </div>
        </div>
        <div class="ds-2col">
            <div class="ds-row">
                <label asp-for="ModifiedDate" class="ds-lbl">แก้ไขล่าสุด</label>
                <input asp-for="ModifiedDate" class="ds-input ds-input-ro" readonly/>
            </div>
            <div class="ds-row">
                <label asp-for="ModifiedBy" class="ds-lbl">แก้ไขโดย</label>
                <input asp-for="ModifiedBy" class="ds-input ds-input-ro" readonly/>
            </div>
        </div>

        @* IsDeleted toggle *@
        <div class="ds-toggle-row">
            <label class="ds-switch">
                <input type="checkbox" asp-for="IsDeleted" id="isDeletedChk" onchange="toggleDeleted(this.checked)"/>
                <span class="ds-slider"></span>
            </label>
            <span style="font-size:13px;font-weight:500">IsDeleted</span>
            <span id="deletedHint" style="font-size:12px;color:var(--ds-text3);margin-left:auto">ปกติ</span>
        </div>

        <div class="ds-actions-sb">
            <div style="display:flex;gap:8px">
                <button type="submit" class="ds-btn-primary">บันทึก</button>
                <a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a>
            </div>
            <a asp-action="Delete" asp-route-id="@Model.Id" id="deleteBtn"
               class="ds-btn-del-ghost" style="display:none">ลบถาวร</a>
        </div>
    </form>
</div>

@section Scripts {
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
<script>
// jQuery Unobtrusive adapter สำหรับ NumericFixedLengthAttribute
$.validator.addMethod("numericfixedlength", function (value, element, params) {
    if (!value) return true;
    if (!/^\d+$/.test(value)) return false;
    return value.length === parseInt(params.length, 10);
});
$.validator.unobtrusive.adapters.add("numericfixedlength", ["length"], function (options) {
    options.rules["numericfixedlength"] = { length: options.params.length };
    options.messages["numericfixedlength"] = options.message;
});
</script>
<script>
(function () {
    window.toggleDeleted = function (on) {
        const hint = document.getElementById('deletedHint');
        const btn  = document.getElementById('deleteBtn');
        hint.textContent = on ? 'ทำเครื่องหมายว่าถูกลบ' : 'ปกติ';
        hint.style.color = on ? '#A32D2D' : 'var(--ds-text3)';
        btn.style.display = on ? 'inline-flex' : 'none';
    };
    const chk = document.getElementById('isDeletedChk');
    if (chk) toggleDeleted(chk.checked);

    // Cascade dropdowns (Type ↔ Brand bidirectional, Brand → Model)
    const ddlType  = document.getElementById('ddlItemType');
    const ddlBrand = document.getElementById('ddlItemBrand');
    const ddlModel = document.getElementById('ddlItemModel');
    if (!ddlType || !ddlBrand || !ddlModel) return;

    const allType  = snap(ddlType);
    const allBrand = snap(ddlBrand);
    const allModel = snap(ddlModel);

    function snap(sel) { return Array.from(sel.options).map(o => ({ value: o.value, text: o.text })); }

    function rebuild(sel, all, allowed, ph) {
        const cur = sel.value;
        sel.innerHTML = '';
        const p = document.createElement('option'); p.value = ''; p.text = ph; sel.appendChild(p);
        all.forEach(o => {
            if (!o.value) return;
            if (!allowed || allowed.includes(String(o.value))) {
                const opt = document.createElement('option'); opt.value = o.value; opt.text = o.text; sel.appendChild(opt);
            }
        });
        sel.value = [...sel.options].some(o => o.value === cur) ? cur : '';
    }

    let busy = false;
    ddlType.addEventListener('change', function () {
        if (busy) return; busy = true;
        rebuild(ddlBrand, allBrand, this.value ? (typeToBrandsMap[this.value] || []).map(String) : null, '-- เลือกยี่ห้อ --');
        busy = false;
        ddlBrand.dispatchEvent(new Event('change'));
    });
    ddlBrand.addEventListener('change', function () {
        if (busy) return; busy = true;
        rebuild(ddlModel, allModel, this.value ? (brandToModelsMap[this.value] || []).map(m => String(m.Value ?? m.value)) : null, '-- เลือกรุ่น --');
        rebuild(ddlType,  allType,  this.value ? (brandToTypesMap[this.value]  || []).map(String) : null, '-- เลือกประเภทอุปกรณ์ --');
        busy = false;
    });

    // ล้าง cascade (Type / Brand / Model) ทั้งหมด
    const btnClearCascade = document.getElementById('btnClearCascade');
    if (btnClearCascade) btnClearCascade.addEventListener('click', function () {
        busy = true;
        ddlType.value = '';
        ddlBrand.value = '';
        ddlModel.value = '';
        rebuild(ddlBrand, allBrand, null, '-- เลือกยี่ห้อ --');
        rebuild(ddlModel, allModel, null, '-- เลือกรุ่น --');
        rebuild(ddlType,  allType,  null, '-- เลือกประเภทอุปกรณ์ --');
        busy = false;
    });
})();
</script>
}
