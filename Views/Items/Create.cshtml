@model KlangIT_V3.ViewModels.ItemCreateViewModel
@{
    ViewData["Title"] = "เพิ่มวัสดุ";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<script>
    const typeToBrandsMap  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.TypeToBrandsMap));
    const brandToTypesMap  = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BrandToTypesMap));
    const brandToModelsMap = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.BrandToModelsMap));
</script>

<h1 class="ds-page-title">เพิ่มวัสดุ</h1>

<div class="ds-card" style="max-width:560px">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3" style="display:none"></div>

        

        @* ── Asset ID ── *@
        <div class="ds-row">
            <span class="ds-lbl">เลขครุภัณฑ์</span>
            <div class="ds-asset-row">
                <div style="display:flex;flex-direction:column;width:72px">
                    <input asp-for="AssetId1" class="ds-input" maxlength="4" placeholder="01"/>
                    <span asp-validation-for="AssetId1" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;flex:1">
                    <input asp-for="AssetId2" class="ds-input" placeholder="00000000"/>
                    <span asp-validation-for="AssetId2" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;flex:1">
                    <input asp-for="AssetId3" class="ds-input" placeholder="00000000"/>
                    <span asp-validation-for="AssetId3" class="text-danger small"></span>
                </div>
                <div class="ds-asset-sep">-</div>
                <div style="display:flex;flex-direction:column;width:82px">
                    <input asp-for="AssetId4" class="ds-input" placeholder="00000"/>
                    <span asp-validation-for="AssetId4" class="text-danger small"></span>
                </div>
            </div>
            <p class="ds-hint">รูปแบบ: XXXX-XXXXXXXX-XXXXXXXX-XXXXX</p>
        </div>

        <div class="ds-row">
            <label asp-for="OtherAssetId" class="ds-lbl">เลขทะเบียนทรัพย์สินแบบอื่น</label>
            <input asp-for="OtherAssetId" class="ds-input"/>
            <span asp-validation-for="OtherAssetId" class="text-danger small"></span>
        </div>

        <div class="ds-row">
            <label asp-for="SerialNo" class="ds-lbl">Serial Number</label>
            <input asp-for="SerialNo" class="ds-input"/>
            <span asp-validation-for="SerialNo" class="text-danger small"></span>
        </div>

        <hr class="ds-divider"/>

        <div class="ds-2col">
            <div class="ds-row">
                <label asp-for="SelectedItemTypeId" class="ds-lbl">ประเภทอุปกรณ์</label>
                <select asp-for="SelectedItemTypeId" id="ddlItemType" class="ds-select" asp-items="Model.ItemTypes"></select>
                <span asp-validation-for="SelectedItemTypeId" class="text-danger small"></span>
            </div>
            <div class="ds-row">
                <label asp-for="SelectedItemBrandId" class="ds-lbl">ยี่ห้อ</label>
                <select asp-for="SelectedItemBrandId" id="ddlItemBrand" class="ds-select" asp-items="Model.ItemBrands"></select>
                <span asp-validation-for="SelectedItemBrandId" class="text-danger small"></span>
            </div>
        </div>

        <div class="ds-row">
            <label asp-for="SelectedItemModelId" class="ds-lbl">รุ่น</label>
            <select asp-for="SelectedItemModelId" id="ddlItemModel" class="ds-select" asp-items="Model.ItemModels"></select>
            <span asp-validation-for="SelectedItemModelId" class="text-danger small"></span>
        </div>

        <div class="ds-row">
            <label asp-for="ItemDescription" class="ds-lbl">คำอธิบาย</label>
            <input asp-for="ItemDescription" class="ds-input"/>
            <span asp-validation-for="ItemDescription" class="text-danger small"></span>
        </div>

        @* ── Image upload ── *@
        <div class="ds-row">
            <label asp-for="ItemImageFile" class="ds-lbl">รูปภาพอุปกรณ์</label>
            <div class="ds-img-preview" id="imgPreviewBox">
                <span>ยังไม่มีรูป</span>
            </div>
            <input asp-for="ItemImageFile" type="file" class="ds-input"
                   style="height:auto;padding:6px 10px"
                   accept="image/*" id="inputImageFile"/>
            <p class="ds-hint">จำกัดขนาดไฟล์ไม่เกิน 2 MB (.jpg .png .gif .webp)</p>
            <span asp-validation-for="ItemImageFile" class="text-danger small"></span>
        </div>

        <hr class="ds-divider"/>

        @* ── IsBulk Toggle ── *@
        <div class="ds-toggle-row">
            <label class="ds-switch">
                <input type="checkbox" asp-for="IsBulk" id="isBulkChk" />
                <span class="ds-slider"></span>
            </label>
            <span style="font-size:13px;font-weight:500">เป็นกลุ่มวัสดุ</span>
            <span id="bulkHint" style="font-size:12px;color:var(--ds-text3);margin-left:auto">ปิด — จำนวนถูกกำหนดเป็น 1</span>
        </div>

        <div class="ds-2col">
            <div class="ds-row">
                <label asp-for="TotalAmount" class="ds-lbl">จำนวนทั้งหมด</label>
                <input asp-for="TotalAmount" id="totalQtyInput" class="ds-input ds-input-ro"/>
                <span asp-validation-for="TotalAmount" class="text-danger small"></span>
                <p id="totalAmountError" class="text-danger small" style="display:none">จำนวนทั้งหมดต้องเป็น 1 เมื่อไม่ใช่กลุ่มวัสดุ</p>
            </div>
            <div class="ds-row">
                <label asp-for="MinimumAmount" class="ds-lbl">จำนวนขั้นต่ำ</label>
                <input asp-for="MinimumAmount" id="minAmountInput" class="ds-input"/>
                <span asp-validation-for="MinimumAmount" class="text-danger small"></span>
                <p id="minAmountError" class="text-danger small" style="display:none">จำนวนขั้นต่ำต้องน้อยกว่าจำนวนทั้งหมด</p>
            </div>
        </div>

        @* ItemStatus fixed to Available on create *@
        <input type="hidden" asp-for="SelectedItemStatus" value="1"/>
        <div class="ds-row">
            <span class="ds-lbl">สถานะของวัสดุ/ครุภัณฑ์</span>
            <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--ds-bg2);border-radius:var(--ds-radius-md)">
                <span class="ds-badge ds-badge-teal">ใช้งานได้</span>
                <span style="font-size:12px;color:var(--ds-text3)">(กำหนดโดยระบบ)</span>
            </div>
        </div>

        <div class="ds-row">
            <label asp-for="Remarks" class="ds-lbl">หมายเหตุ</label>
            <input asp-for="Remarks" class="ds-input"/>
            <span asp-validation-for="Remarks" class="text-danger small"></span>
        </div>

        <div class="ds-actions">
            <button type="submit" class="ds-btn-primary">บันทึก</button>
            <a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a>
        </div>
    </form>
</div>

@section Scripts {
@{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
<script>
(function () {
    const isBulkChk   = document.getElementById('isBulkChk');
    const totalInput  = document.getElementById('totalQtyInput');
    const minInput    = document.getElementById('minAmountInput');
    const bulkHint    = document.getElementById('bulkHint');
    const totalErr    = document.getElementById('totalAmountError');
    const minErr      = document.getElementById('minAmountError');
    const ddlType     = document.getElementById('ddlItemType');
    const ddlBrand    = document.getElementById('ddlItemBrand');
    const ddlModel    = document.getElementById('ddlItemModel');

    const allType  = snap(ddlType);
    const allBrand = snap(ddlBrand);
    const allModel = snap(ddlModel);

    function snap(sel) { return Array.from(sel.options).map(o => ({ value: o.value, text: o.text })); }

    function rebuild(sel, all, allowed, ph) {
        const cur = sel.value;
        sel.innerHTML = '';
        const p = document.createElement('option'); p.value = ''; p.text = ph; sel.appendChild(p);
        all.forEach(o => {
            if (!o.value) return;
            if (!allowed || allowed.includes(String(o.value))) {
                const opt = document.createElement('option'); opt.value = o.value; opt.text = o.text; sel.appendChild(opt);
            }
        });
        sel.value = [...sel.options].some(o => o.value === cur) ? cur : '';
    }

    function getHiddenTotal() {
        const h = document.querySelector('input[type=hidden][name=TotalAmount]');
        return h ? parseInt(h.value) || 0 : parseInt(totalInput.value) || 0;
    }

    function applyBulk(on) {
        totalInput.disabled = !on;
        totalInput.classList.toggle('ds-input-ro', !on);
        if (!on) {
            totalInput.value = 1;
            bulkHint.textContent = 'ปิด — จำนวนถูกกำหนดเป็น 1';
            let h = document.querySelector('input[type=hidden][name=TotalAmount]');
            if (!h) { h = document.createElement('input'); h.type = 'hidden'; h.name = 'TotalAmount'; isBulkChk.closest('form').appendChild(h); }
            h.value = 1;
        } else {
            bulkHint.textContent = 'เปิด — ระบุจำนวนได้เอง';
            const h = document.querySelector('input[type=hidden][name=TotalAmount]');
            if (h) h.remove();
        }
        validateTotal();
    }

    function validateTotal() {
        if (!isBulkChk.checked && parseInt(totalInput.value) !== 1) {
            totalInput.classList.add('is-invalid'); totalErr.style.display = 'block';
        } else { totalInput.classList.remove('is-invalid'); totalErr.style.display = 'none'; }
    }

    function validateMin() {
        const total = getHiddenTotal();
        const min   = parseInt(minInput.value) || 0;
        if (min >= total) { minInput.classList.add('is-invalid'); minErr.style.display = 'block'; }
        else { minInput.classList.remove('is-invalid'); minErr.style.display = 'none'; }
    }

    isBulkChk.addEventListener('change', () => applyBulk(isBulkChk.checked));
    totalInput.addEventListener('input', () => { validateTotal(); validateMin(); });
    minInput.addEventListener('input', validateMin);
    applyBulk(isBulkChk.checked);

    // Image preview
    document.getElementById('inputImageFile').addEventListener('change', function () {
        const f = this.files[0]; if (!f) return;
        const r = new FileReader();
        r.onload = e => {
            const box = document.getElementById('imgPreviewBox');
            box.innerHTML = '<img src="' + e.target.result + '">';
        };
        r.readAsDataURL(f);
    });

    // Cascade dropdowns
    let busy = false;
    ddlType.addEventListener('change', function () {
        if (busy) return; busy = true;
        rebuild(ddlBrand, allBrand, this.value ? (typeToBrandsMap[this.value] || []).map(String) : null, '-- เลือกยี่ห้อ --');
        busy = false;
        ddlBrand.dispatchEvent(new Event('change'));
    });
    ddlBrand.addEventListener('change', function () {
        if (busy) return; busy = true;
        rebuild(ddlModel, allModel, this.value ? (brandToModelsMap[this.value] || []).map(m => String(m.Value ?? m.value)) : null, '-- เลือกรุ่น --');
        rebuild(ddlType,  allType,  this.value ? (brandToTypesMap[this.value]  || []).map(String) : null, '-- เลือกประเภทอุปกรณ์ --');
        busy = false;
    });
})();
</script>
}
