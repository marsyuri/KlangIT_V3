@model DateTime
@{
    string[] thaiMonths = {
        "ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.",
        "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."
    };
    var buddhistYear = Model.Year + 543;
    var month = thaiMonths[Model.Month - 1];
}
@($"{Model.Day:D2} {month} {buddhistYear} เวลา {Model:HH:mm} น.")
