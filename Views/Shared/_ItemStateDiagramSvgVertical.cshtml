@* _ItemStateDiagramSvgVertical.cshtml
   แนวตั้ง - วาดกล่องทุกกล่องก่อน แล้วค่อยวาดเส้นทีหลัง
   เพื่อให้เส้นอยู่บน z-order สูงสุด ไม่ถูกกล่องทับ
   Model: "borrow" | "return" | "damage" | "repair" | else = full
*@
@model string
@{
    var mode = Model ?? string.Empty;
    var svgId = "ds-svg-v-" + mode.ToLower().Replace(" ", "-");
    var mkrId = "mk-" + svgId;

    double borrowSW = mode == "borrow" ? 2.5 : 1.5;
    string borrowLbl = mode == "borrow" ? "ยืม ★" : "ยืม";
    string borrowFW = mode == "borrow" ? "bold" : "normal";
    int borrowFS = mode == "borrow" ? 18 : 12;

    double returnSW = mode == "return" ? 2.5 : 1.5;
    string returnLbl = mode == "return" ? "คืน ★" : "คืน";
    string returnFW = mode == "return" ? "bold" : "normal";
    int returnFS = mode == "return" ? 18 : 12;
    int returnY = mode == "return" ? 170 : 163;

    double damageSW = mode == "damage" ? 2.5 : 1.5;
    string damageLbl = mode == "damage" ? "เสียหาย ★" : "เสียหาย";
    string damageFW = mode == "damage" ? "bold" : "normal";
    int damageFS = mode == "damage" ? 18 : 12;

    double repairSW = mode == "repair" ? 2.5 : 1.5;
    string repairLbl = mode == "repair" ? "ซ่อมแล้ว ★" : "ซ่อมแซม";
    string repairFW = mode == "repair" ? "bold" : "normal";
    int repairFS = mode == "repair" ? 18 : 12;

    double availSW = (mode == "borrow" || mode == "damage") ? 2.0 : 1.5;
    double bwdSW = mode == "return" ? 2.0 : 1.5;
    double damagedBoxSW = mode == "repair" ? 2.0 : 1.5;
}

<svg id="@svgId" width="100%" viewBox="0 0 560 600"
     xmlns="http://www.w3.org/2000/svg" role="img">
    <title>แผนผังการเปลี่ยนสถานะวัสดุ/ครุภัณฑ์ (แนวตั้ง)</title>
    <defs>
        <marker id="@mkrId" viewBox="0 0 10 10" refX="8" refY="5"
                markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke"
                  stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </marker>
    </defs>

    @{
        string m = $"url(#{mkrId})";
    }

    @* ════════════════════════════════════════
       PASS 1: วาดกล่องทุกกล่องก่อน
       offset +60 จากเดิม → content อยู่กลาง viewBox
       กล่องซ้าย  x=140..270  center-x=205
       ถูกยืม      x=355..485  center-x=420
       ════════════════════════════════════════ *@

    @* พร้อมใช้งาน (teal) *@
    <rect x="140" y="100" width="130" height="60" rx="8"
          fill="#E1F5EE" stroke="#5DCAA5" stroke-width="@availSW" />
    <text x="205" y="133" text-anchor="middle" dominant-baseline="central"
          font-size="15" font-weight="500" fill="#085041" font-family="sans-serif">พร้อมใช้งาน</text>

    @* ถูกยืม (amber) *@
    <rect x="355" y="100" width="130" height="60" rx="8"
          fill="#FAEEDA" stroke="#EF9F27" stroke-width="@bwdSW" />
    <text x="420" y="133" text-anchor="middle" dominant-baseline="central"
          font-size="15" font-weight="500" fill="#633806" font-family="sans-serif">ถูกยืม</text>

    @* ชำรุด (coral) *@
    <rect x="140" y="250" width="130" height="60" rx="8"
          fill="#FAECE7" stroke="#F0997B" stroke-width="@damagedBoxSW" />
    <text x="205" y="283" text-anchor="middle" dominant-baseline="central"
          font-size="15" font-weight="500" fill="#712B13" font-family="sans-serif">ชำรุด</text>

    @* จำหน่ายออก (blue) *@
    <rect x="140" y="400" width="130" height="60" rx="8"
          fill="#E6F1FB" stroke="#85B7EB" stroke-width="1.5" />
    <text x="205" y="433" text-anchor="middle" dominant-baseline="central"
          font-size="15" font-weight="500" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    @* ════════════════════════════════════════
       PASS 2: วาดเส้นทั้งหมดทีหลัง (อยู่บนกล่อง)
       ════════════════════════════════════════ *@

    @* เริ่มต้น → พร้อมใช้งาน *@
    <circle cx="205" cy="40" r="11" fill="#444441" />
    <text x="205" y="20" text-anchor="middle" font-size="12"
          fill="#888780" font-family="sans-serif">เริ่มต้น</text>
    <line x1="205" y1="51" x2="205" y2="97"
          stroke="#444441" stroke-width="1.5" marker-end="@m" />

    @* ยืม: พร้อมใช้งาน(right=270) → ถูกยืม(left=355) เส้น 85px *@
    <path d="M 270 120 L 352 120"
          fill="none" stroke="#0F6E56" stroke-width="@borrowSW" marker-end="@m" />
    <text x="312" y="106" text-anchor="middle" font-size="@borrowFS"
          fill="#0F6E56" font-weight="@borrowFW" font-family="sans-serif">@borrowLbl</text>

    @* คืน: ถูกยืม(left=355) → พร้อมใช้งาน(right=270) เส้น 85px *@
    <path d="M 355 148 L 273 148"
          fill="none" stroke="#993C1D" stroke-width="@returnSW" marker-end="@m" />
    <text x="312" y="@returnY" text-anchor="middle" font-size="@returnFS"
          fill="#993C1D" font-weight="@returnFW" font-family="sans-serif">@returnLbl</text>

    @* เสียหาย: เส้นขวา x=220 (center+15), text ห่าง 15px *@
    <path d="M 220 160 L 220 248"
          fill="none" stroke="#0F6E56" stroke-width="@damageSW" marker-end="@m" />
    <text x="225" y="208" font-size="@damageFS"
          fill="#0F6E56" font-weight="@damageFW" font-family="sans-serif">@damageLbl</text>

    @* ซ่อมแซม/ซ่อมแล้ว: เส้นซ้าย x=190 (center-15), text ห่าง 15px *@
    <path d="M 190 250 L 190 162"
          fill="none" stroke="#993C1D" stroke-width="@repairSW" marker-end="@m" />
    <text x="185" y="208" text-anchor="end" font-size="@repairFS"
          fill="#993C1D" font-weight="@repairFW" font-family="sans-serif">@repairLbl</text>

    @* จำหน่ายออก: ชำรุด → จำหน่ายออก เส้น center=205, text ซ้ายเส้น *@
    <path d="M 205 310 L 205 397"
          fill="none" stroke="#0C447C" stroke-width="1.5" marker-end="@m" />
    <text x="200" y="357" text-anchor="end" font-size="12"
          fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    @* จำหน่ายออก: พร้อมใช้งาน → จำหน่ายออก (arc ซ้าย x=105)
       x=105 พ้นกล่องซ้าย=140, text เริ่ม x=60 → "จำหน่ายออก" 10px×7≈43px → x=60-43=17 อยู่ในกรอบ *@
    <path d="M 140 130 L 105 130 L 105 430 L 138 430"
          fill="none" stroke="#0C447C" stroke-width="1.5" marker-end="@m" />
    <text x="100" y="295" text-anchor="end" font-size="12"
          fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    @* สิ้นสุด *@
    <line x1="205" y1="460" x2="205" y2="507"
          stroke="#444441" stroke-width="1.5" marker-end="@m" />
    <g transform="translate(205,520)">
        <circle cx="0" cy="0" r="11" fill="none" stroke="#444441" stroke-width="2" />
        <circle cx="0" cy="0" r="4" fill="#444441" />
    </g>
    <text x="205" y="550" text-anchor="middle" font-size="12"
          fill="#888780" font-family="sans-serif">สิ้นสุด</text>

    @* Legend *@
    <g transform="translate(80,570)">
        <line x1="0" y1="0" x2="18" y2="0" stroke="#0F6E56" stroke-width="2" />
        <text x="24" y="4" font-size="10" fill="#0F6E56" font-family="sans-serif">ยืม / เสียหาย</text>
        <line x1="135" y1="0" x2="153" y2="0" stroke="#993C1D" stroke-width="2" />
        <text x="159" y="4" font-size="10" fill="#993C1D" font-family="sans-serif">คืน / ซ่อมแซม</text>
        <line x1="300" y1="0" x2="318" y2="0" stroke="#0C447C" stroke-width="2" />
        <text x="324" y="4" font-size="10" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>
    </g>
</svg>
