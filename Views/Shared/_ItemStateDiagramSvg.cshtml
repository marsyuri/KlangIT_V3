@model string
@{
    bool isBorrow = Model == "borrow";
    bool isReturn = Model == "return";
    string svgId  = "ds-svg-" + (Model ?? "diagram");

    string borrowStroke = isBorrow ? "#0F6E56" : "#0F6E56";
    double borrowWidth  = isBorrow ? 2.5 : 1.5;
    string returnStroke = isReturn ? "#993C1D" : "#993C1D";
    double returnWidth  = isReturn ? 2.5 : 1.5;

    string borrowLabel  = isBorrow ? "ยืม ★" : "ยืม";
    string returnLabel  = isReturn ? "คืน ★" : "คืน";
    string borrowWeight = isBorrow ? "bold" : "normal";
    string returnWeight = isReturn ? "bold" : "normal";

    string availStroke  = isBorrow ? "#5DCAA5" : "#5DCAA5";
    double availSW      = 1.5;
    string borrowedStroke = isBorrow ? "#EF9F27" : "#EF9F27";
    double borrowedSW   = isReturn ? 2.0 : 1.5;
}

<svg id="@svgId" width="100%" viewBox="0 0 1060 490" xmlns="http://www.w3.org/2000/svg" role="img">
    <title>แผนผังการเปลี่ยนสถานะวัสดุ/ครุภัณฑ์</title>
    <defs>
        <marker id="@(svgId)-mg" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </marker>
    </defs>

    @{ string m = $"url(#{svgId}-mg)"; }

    <line x1="95" y1="240" x2="168" y2="240" stroke="#444441" stroke-width="1.5" marker-end="@m"/>
    <circle cx="80" cy="240" r="10" fill="#444441"/>
    <text x="80" y="275" text-anchor="middle" font-size="12" fill="#888780" font-family="sans-serif">เริ่มต้น</text>

    <rect x="180" y="210" width="160" height="60" rx="8" fill="#E1F5EE" stroke="@availStroke" stroke-width="@availSW"/>
    <text x="260" y="244" text-anchor="middle" dominant-baseline="central" font-size="15" font-weight="500" fill="#085041" font-family="sans-serif">พร้อมใช้งาน</text>

    <rect x="180" y="50" width="160" height="60" rx="8" fill="#FAEEDA" stroke="@borrowedStroke" stroke-width="@borrowedSW"/>
    <text x="260" y="84" text-anchor="middle" dominant-baseline="central" font-size="15" font-weight="500" fill="#633806" font-family="sans-serif">ถูกยืม</text>

    <path d="M 300 210 L 300 118" fill="none" stroke="@borrowStroke" stroke-width="@borrowWidth" marker-end="@m"/>
    <text x="318" y="168" font-size="13" fill="@borrowStroke" font-weight="@borrowWeight" font-family="sans-serif">@borrowLabel</text>

    <path d="M 220 110 L 220 200" fill="none" stroke="@returnStroke" stroke-width="@returnWidth" marker-end="@m"/>
    <text x="202" y="162" font-size="13" fill="@returnStroke" font-weight="@returnWeight" text-anchor="end" font-family="sans-serif">@returnLabel</text>

    <rect x="460" y="210" width="160" height="60" rx="8" fill="#FAECE7" stroke="#F0997B" stroke-width="1.5"/>
    <text x="540" y="244" text-anchor="middle" dominant-baseline="central" font-size="15" font-weight="500" fill="#712B13" font-family="sans-serif">ชำรุด</text>

    <path d="M 340 225 L 458 225" fill="none" stroke="#0F6E56" stroke-width="1.5" marker-end="@m"/>
    <text x="399" y="217" text-anchor="middle" font-size="12" fill="#0F6E56" font-family="sans-serif">เสียหาย</text>

    <path d="M 460 255 L 342 255" fill="none" stroke="#993C1D" stroke-width="1.5" stroke-dasharray="5 4" marker-end="@m"/>
    <text x="401" y="273" text-anchor="middle" font-size="12" fill="#993C1D" font-family="sans-serif">ซ่อมแซม</text>

    <rect x="740" y="210" width="160" height="60" rx="8" fill="#E6F1FB" stroke="#85B7EB" stroke-width="1.5"/>
    <text x="820" y="244" text-anchor="middle" dominant-baseline="central" font-size="15" font-weight="500" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    <path d="M 620 240 L 738 240" fill="none" stroke="#0C447C" stroke-width="1.5" marker-end="@m"/>
    <text x="679" y="232" text-anchor="middle" font-size="12" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    <path d="M 260 270 L 260 360 L 820 360 L 820 272" fill="none" stroke="#0C447C" stroke-width="1.5" marker-end="@m"/>
    <text x="540" y="352" text-anchor="middle" font-size="12" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>

    <path d="M 900 240 L 968 240" fill="none" stroke="#444441" stroke-width="1.5" marker-end="@m"/>
    <g transform="translate(980,240)">
        <circle cx="0" cy="0" r="10" fill="none" stroke="#444441" stroke-width="2"/>
        <circle cx="0" cy="0" r="4" fill="#444441"/>
        <text x="0" y="35" text-anchor="middle" font-size="12" fill="#888780" font-family="sans-serif">สิ้นสุด</text>
    </g>

    <g transform="translate(90,450)">
        <line x1="0" y1="0" x2="24" y2="0" stroke="#0F6E56" stroke-width="2"/>
        <text x="30" y="4" font-size="11" fill="#0F6E56" font-family="sans-serif">ยืม / เสียหาย</text>
        <line x1="148" y1="0" x2="172" y2="0" stroke="#993C1D" stroke-width="2"/>
        <text x="178" y="4" font-size="11" fill="#993C1D" font-family="sans-serif">คืน</text>
        <line x1="216" y1="0" x2="240" y2="0" stroke="#993C1D" stroke-width="2" stroke-dasharray="5 4"/>
        <text x="246" y="4" font-size="11" fill="#993C1D" font-family="sans-serif">ซ่อมแซม</text>
        <line x1="348" y1="0" x2="372" y2="0" stroke="#0C447C" stroke-width="2"/>
        <text x="378" y="4" font-size="11" fill="#0C447C" font-family="sans-serif">จำหน่ายออก</text>
    </g>
</svg>
