@model IEnumerable<KlangIT_V3.Models.ItemTypeToBrand>
@{ ViewData["Title"] = "จับคู่ประเภท-ยี่ห้อ"; }
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:1.5rem">
    <h1 class="ds-page-title" style="margin:0">จับคู่ประเภท-ยี่ห้ออุปกรณ์</h1>
    <a asp-action="Create" class="ds-btn-primary">+ เพิ่มการจับคู่</a>
</div>
<form asp-action="Index" method="get" class="ds-filter-bar">
    <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort"/>
    <input type="text" name="searchBox" class="ds-input" style="width:220px" placeholder="ค้นหา..." value="@ViewBag.CurrentSearch"/>
    <button type="submit" class="ds-btn-primary">ค้นหา</button>
</form>
<div class="ds-table-wrap"><table class="ds-table">
    <thead><tr>
        <th style="width:48px">#</th>
        <th><a asp-action="Index" asp-route-sortOrder="@ViewBag.SortByType" asp-route-searchBox="@ViewBag.CurrentSearch">ประเภท ↕</a></th>
        <th><a asp-action="Index" asp-route-sortOrder="@ViewBag.SortByBrand" asp-route-searchBox="@ViewBag.CurrentSearch">ยี่ห้อ ↕</a></th>
        <th></th>
    </tr></thead>
    <tbody>
        @if (!Model.Any()) { <tr><td colspan="4" class="ds-table-empty">ไม่พบข้อมูล</td></tr> }
        else { int row=0; foreach(var item in Model) { row++;
            <tr>
                <td style="color:var(--ds-text3)">@row</td>
                <td>@item.ItemType?.Name</td>
                <td>@item.ItemBrand?.Name</td>
                <td><div class="ds-tbl-actions">
                    <a asp-action="Edit"    asp-route-id="@item.Id" class="ds-btn-ghost ds-tbl-btn">แก้ไข</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="ds-btn-ghost ds-tbl-btn">รายละเอียด</a>
                    <a asp-action="Delete"  asp-route-id="@item.Id" class="ds-btn-del-ghost ds-tbl-btn">ลบ</a>
                </div></td>
            </tr>
        } }
    </tbody>
</table></div>
