@model KlangIT_V3.ViewModels.ItemBrandDeleteViewModel
@{ ViewData["Title"] = "ลบยี่ห้ออุปกรณ์"; }
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">ลบยี่ห้ออุปกรณ์</h1>
<p class="ds-page-sub">กรุณาตรวจสอบรายละเอียดก่อนดำเนินการลบ</p>
<div style="max-width:420px">
    <span class="ds-section-lbl">ข้อมูลยี่ห้อ</span>
    <div class="ds-card">
        <div class="ds-field-grid">
            <span class="ds-field-label">ยี่ห้อ</span>          <span class="ds-field-value">@Model.Name</span>
            <span class="ds-field-label">แก้ไขล่าสุด</span>     <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.ModifiedDate.ToString("dd MMM yyyy")</span>
        </div>
    </div>
    @if (!Model.CanDelete) {
        <div class="ds-blocked-box">
            <div class="ds-blocked-title">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="#A32D2D" stroke-width="1.5"/><path d="M5 5L11 11M11 5L5 11" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/></svg>
                ไม่สามารถลบได้
            </div>
            <p class="ds-blocked-desc">มีรุ่นอุปกรณ์ @Model.ItemModelCount รายการ และอุปกรณ์ @Model.ItemCount รายการที่ผูกกับยี่ห้อนี้</p>
            <p class="ds-blocked-note">กรุณาลบรุ่นอุปกรณ์และอุปกรณ์ที่เกี่ยวข้องก่อน</p>
        </div>
        <div class="ds-actions"><button class="ds-btn-danger" disabled>ยืนยันการลบ</button><a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a></div>
    } else {
    <div class="ds-danger-box">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L16.5 15H1.5L9 2Z" stroke="#A32D2D" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7V10" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="13" r=".75" fill="#A32D2D"/></svg>
        <div>
            <p class="ds-danger-title">การดำเนินการนี้ไม่สามารถย้อนกลับได้</p>
            <p class="ds-danger-desc">ข้อมูลจะถูกลบออกจากระบบ (soft delete)</p>
        </div>
    </div>
        <form asp-action="Delete">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"/>
        <div class="ds-actions"><button type="submit" class="ds-btn-danger">ยืนยันการลบ</button><a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a></div></form>
    }
</div>
