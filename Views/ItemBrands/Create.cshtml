@model KlangIT_V3.ViewModels.ItemBrandViewModel

@{
    ViewData["Title"] = "เพิ่มยี่ห้ออุปกรณ์";
}

<h1>เพิ่มยี่ห้ออุปกรณ์</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="form-group mb-4">
                <label asp-for="Name" class="control-label">ชื่อยี่ห้ออุปกรณ์</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="form-group mb-4">
                <input type="submit" value="บันทึก" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
