@model KlangIT_V3.ViewModels.SectionDeleteViewModel
@{ ViewData["Title"] = "ลบหน่วยงาน"; }
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">ลบหน่วยงาน</h1>
<p class="ds-page-sub">กรุณาตรวจสอบรายละเอียดก่อนดำเนินการลบ</p>
<div style="max-width:420px">
    <span class="ds-section-lbl">ข้อมูลหน่วยงาน</span>
    <div class="ds-card">
        <div class="ds-field-grid">
            <span class="ds-field-label">ฝ่าย/กลุ่มงาน</span>  <span class="ds-field-value">@Model.DepartmentName</span>
            <span class="ds-field-label">หน่วยงาน</span>         <span class="ds-field-value">@Model.Name</span>
        </div>
    </div>
    @if (Model.HasDependency) {
        <div class="ds-warn-box">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L16.5 15H1.5L9 2Z" stroke="#854F0B" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7V10" stroke="#854F0B" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="13" r=".75" fill="#854F0B"/></svg>
            <div>
                <p class="ds-warn-title">มีประวัติการยืม-คืน @Model.BorrowHistoryCount รายการที่อ้างอิงหน่วยงานนี้</p>
                <p class="ds-warn-desc">ลบได้ แต่ประวัติที่อ้างอิงจะแสดงข้อมูลหน่วยงานไม่สมบูรณ์</p>
            </div>
        </div>
    }
    <div class="ds-danger-box">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2L16.5 15H1.5L9 2Z" stroke="#A32D2D" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 7V10" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="13" r=".75" fill="#A32D2D"/></svg>
        <div><p class="ds-danger-title">การดำเนินการนี้ไม่สามารถย้อนกลับได้</p><p class="ds-danger-desc">ข้อมูลจะถูกลบออกจากระบบ</p></div>
    </div>
    <form asp-action="Delete">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"/>
    <div class="ds-actions"><button type="submit" class="ds-btn-danger">ยืนยันการลบ</button><a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a></div></form>
</div>
