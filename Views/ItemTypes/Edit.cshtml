@model KlangIT_V3.ViewModels.ItemTypeEditViewModel
@{ ViewData["Title"] = "แก้ไขประเภทอุปกรณ์"; }
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">แก้ไขประเภทอุปกรณ์</h1>
<div class="ds-card" style="max-width:360px">
    <form asp-action="Edit">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>
        <input type="hidden" asp-for="Id"/>
        <div class="ds-row">
            <label asp-for="Name" class="ds-lbl">ชื่อประเภท</label>
            <input asp-for="Name" class="ds-input"/>
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="ds-actions">
            <button type="submit" class="ds-btn-primary">บันทึก</button>
            <a asp-action="Index" class="ds-btn-ghost">ยกเลิก</a>
        </div>
    </form>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
