@model KlangIT_V3.Models.ItemModel
@{ ViewData["Title"] = "รายละเอียด รุ่นอุปกรณ์"; }
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">รายละเอียด รุ่นอุปกรณ์</h1>
<div class="ds-card" style="max-width:480px;margin-bottom:1.25rem">
    <div class="ds-field-grid">
        <span class="ds-field-label">ยี่ห้อ</span>           <span class="ds-field-value">@Model.ItemBrand?.Name</span>
        <span class="ds-field-label">รุ่น</span>              <span class="ds-field-value">@Model.Name</span>
        <span class="ds-field-label">วันที่สร้าง</span>       <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")</span>
        <span class="ds-field-label">แก้ไขล่าสุด</span>      <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.ModifiedDate.ToString("dd MMM yyyy HH:mm")</span>
        <span class="ds-field-label">สร้างโดย</span>         <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.CreatedBy</span>
        <span class="ds-field-label">แก้ไขโดย</span>         <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@Model.ModifiedBy</span>
    </div>
</div>
<div class="ds-actions">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="ds-btn-primary">แก้ไข</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="ds-btn-del-ghost">ลบ</a>
    <a asp-action="Index" class="ds-btn-ghost">กลับรายการ</a>
</div>
