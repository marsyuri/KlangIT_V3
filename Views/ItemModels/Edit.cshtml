@model KlangIT_V3.ViewModels.ItemModelEditViewModel

@{
    ViewData["Title"] = "แก้ไขรุ่นอุปกรณ์";
}

<h1>แก้ไขรุ่นอุปกรณ์</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group mb-4">
                <label asp-for="SelectedItemBrandId" class="control-label">ยี่ห้อ</label>
                <select asp-for="SelectedItemBrandId" class="form-control" asp-items="Model.ItemBrands"></select>
                <span asp-validation-for="SelectedItemBrandId" class="text-danger small"></span>
            </div>
            <div class="form-group mb-4">
                <label asp-for="Name" class="control-label">รุ่น</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="form-group mb-4">
                <input type="submit" value="บันทึก" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
