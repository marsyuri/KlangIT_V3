@using KlangIT_V3.Models.Enums
@model KlangIT_V3.ViewModels.ReturnCreateViewModel
@{
    ViewData["Title"] = "ทำการคืน";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")
@await Html.PartialAsync("~/Views/Shared/_ItemStateDiagram.cshtml")

<h1 class="ds-page-title">ทำการคืน</h1>

<div class="ds-page-layout">

    @* ── Left: State diagram ── *@
    <div>
        <div class="ds-diagram-wrap">
            <p class="ds-diagram-title">แผนผังการเปลี่ยนสถานะ</p>
            @await Html.PartialAsync("~/Views/Shared/_ItemStateDiagramSvgVertical.cshtml", "return")
        </div>
    </div>

    @* ── Right: Return form ── *@
    <div class="ds-card">
        <span class="ds-section-lbl">รายละเอียดการคืน</span>
        <form asp-action="Return">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="ItemId"/>
            <input type="hidden" asp-for="ItemStatus"/>
            <input type="hidden" asp-for="RequestUser"/>
            <input type="hidden" asp-for="SelectedDepartmentId"/>
            <input type="hidden" asp-for="SelectedSectionId"/>

            <div class="ds-row">
                <label asp-for="ItemHeader" class="ds-lbl">ข้อมูลวัสดุ</label>
                <input asp-for="ItemHeader" class="ds-input ds-input-ro" readonly/>
            </div>

            <div class="ds-row">
                <label asp-for="ItemAssetId" class="ds-lbl">เลขทะเบียนทรัพย์สิน</label>
                <input asp-for="ItemAssetId" class="ds-input ds-input-ro" readonly
                       style="font-family:monospace;font-size:12px"/>
            </div>

            <div class="ds-row">
                <span class="ds-lbl">สถานะของวัสดุ</span>
                <div style="padding:8px 12px;background:var(--ds-bg2);border-radius:var(--ds-radius-md)">
                    @{
                        string badgeCls = Model.ItemStatus == ItemStatusEnum.Available
                            ? "ds-badge ds-badge-teal" : "ds-badge ds-badge-amber";
                    }
                    <span class="@badgeCls">@Html.DisplayFor(m => m.ItemStatus)</span>
                </div>
            </div>

            <div class="ds-row">
                <label asp-for="RequestUser" class="ds-lbl">ผู้ยืม</label>
                <input value="@Model.RequestUser" class="ds-input ds-input-ro" readonly/>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <span class="ds-lbl">ฝ่าย/กลุ่มงาน</span>
                    <select asp-for="SelectedDepartmentId" class="ds-select ds-input-ro"
                            asp-items="Model.Departments" disabled></select>
                </div>
                <div class="ds-row">
                    <span class="ds-lbl">หน่วยงาน</span>
                    <select asp-for="SelectedSectionId" class="ds-select ds-input-ro"
                            asp-items="Model.Sections" disabled></select>
                </div>
            </div>

            <div class="ds-row">
                <span class="ds-lbl">วันที่ยืม</span>
                <input value="@Model.BorrowDate.ToString("dd MMM yyyy")" class="ds-input ds-input-ro" readonly/>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <label asp-for="Itstaff" class="ds-lbl">ผู้ดำเนินการ (IT)</label>
                    <input asp-for="Itstaff" class="ds-input"/>
                    <span asp-validation-for="Itstaff" class="text-danger small"></span>
                </div>
                <div class="ds-row">
                    <label asp-for="ReturnAmount" class="ds-lbl">จำนวนที่คืน</label>
                    <input asp-for="ReturnAmount" class="ds-input" type="number" min="1"/>
                    <span asp-validation-for="ReturnAmount" class="text-danger small"></span>
                </div>
            </div>

            <div class="ds-actions">
                <button type="submit" class="ds-btn-primary">บันทึกการคืน</button>
                <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.ItemId"
                   class="ds-btn-ghost">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
