@using KlangIT_V3.Models.Enums
@model KlangIT_V3.ViewModels.ReturnCreateViewModel

@{
    ViewData["Title"] = "ทำการคืน";
}

<div class="container py-4">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="fs-3 fw-bold mb-1">
                <i class="bi bi-box-arrow-up-right text-primary me-2"></i>ทำการคืน
            </h1>
        </div>
    </div>

    <div class="row g-4">

        <!-- Left: Reference Image Card -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    <img src="~/Images/ItemStatesThai_V2.png"
                         class="img-fluid rounded"
                         data-bs-toggle="modal"
                         data-bs-target="#imgModal"
                         style="max-width:100%; max-height:320px; object-fit:contain; cursor:zoom-in;" />
                    <div class="text-center text-muted small mt-2">
                        <i class="bi bi-zoom-in me-1"></i>คลิกที่รูปเพื่อขยาย
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Borrow Form Card -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="card-title mb-0 fw-semibold">
                        <i class="bi bi-pencil-square text-primary me-2"></i>รายละเอียดการคืน
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Return">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="ItemId" />
                        <div class="mb-4">
                            <label asp-for="ItemHeader" class="form-label fw-semibold">ข้อมูลวัสดุ</label>
                            <input asp-for="ItemHeader" class="form-control bg-light" readonly />
                        </div>

                        <div class="mb-4">
                            <label asp-for="ItemAssetId" class="form-label fw-semibold">เลขทะเบียนทรัพย์สิน</label>
                            <input asp-for="ItemAssetId" class="form-control bg-light" readonly />
                        </div>

                        <input type="hidden" asp-for="ItemStatus" />
                        <div class="mb-4">
                            <label asp-for="ItemStatus" class="form-label fw-semibold">สถานะของวัสดุ</label>
                            @{
                                var statusClass = Model.ItemStatus == ItemStatusEnum.Available
                                    ? "text-success"
                                    : "text-danger";
                            }

                            <div class="form-control bg-light fw-bold @statusClass">
                                @Html.DisplayFor(model => model.ItemStatus)
                            </div>
                        </div>

                        <input type="hidden" asp-for="RequestUser" />
                        <div class="mb-4">
                            <label asp-for="RequestUser" class="form-label fw-semibold">ผู้ยืม</label>
                            <input asp-for="RequestUser" class="form-control" disabled />
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-4">
                                <label asp-for="SelectedDepartmentId" class="form-label fw-semibold"></label>
                                <select asp-for="SelectedDepartmentId" class="form-select" disabled asp-items="Model.Departments"></select>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="SelectedSectionId" class="form-label fw-semibold"></label>
                                <select asp-for="SelectedSectionId" class="form-select" disabled asp-items="Model.Sections"></select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Itstaff" class="form-label fw-semibold">ผู้ดำเนินการ</label>
                                <input asp-for="Itstaff" class="form-control" />
                                <span asp-validation-for="Itstaff" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="ReturnAmount" class="form-label fw-semibold">จำนวนที่คืน</label>
                                <input asp-for="ReturnAmount" class="form-control" />
                                <span asp-validation-for="ReturnAmount" class="text-danger small"></span>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="Items"
                                   asp-action="Details"
                                   asp-route-id="@Model.ItemId"
                                   class="btn btn-secondary px-4">
                                <i class="bi bi-arrow-left me-1"></i> ยกเลิก
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-check-circle me-1"></i> บันทึกการคืน
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Zoom Modal -->
<div class="modal fade" id="imgModal" tabindex="-1" aria-labelledby="imgModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 bg-transparent">
            <div class="modal-body text-center p-0">
                <img src="~/Images/ItemStatesThai_V2.png"
                     class="img-fluid"
                     data-bs-dismiss="modal"
                     style="cursor:zoom-out;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}