@model KlangIT_V3.ViewModels.BorrowHistoryDeleteViewModel
@{
    ViewData["Title"] = "ลบประวัติการยืม";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">ลบประวัติการยืม</h1>
<p class="ds-page-sub">กรุณาตรวจสอบรายละเอียดก่อนดำเนินการลบ</p>

<div style="max-width:560px">
    <span class="ds-section-lbl">ข้อมูลการยืม</span>
    <div class="ds-card">
        <div class="ds-field-grid">
            <span class="ds-field-label">อุปกรณ์</span>
            <span class="ds-field-value">@Model.ItemHeader</span>

            <span class="ds-field-label">เลขทะเบียน</span>
            <span class="ds-field-value" style="font-family:monospace;font-size:12px">@Model.ItemAssetId</span>

            <span class="ds-field-label">ผู้ยืม</span>
            <span class="ds-field-value">@Model.RequestUser</span>

            <span class="ds-field-label">ฝ่าย / หน่วยงาน</span>
            <span class="ds-field-value">@Model.DepartmentName / @Model.SectionName</span>

            <span class="ds-field-label">วันที่ยืม</span>
            <span class="ds-field-value">@Model.BorrowDate.ToString("dd MMM yyyy HH:mm")</span>

            <span class="ds-field-label">สถานะ</span>
            <span class="ds-field-value">
                @if (Model.IsReturn)
                {
        @:คืนแล้ว
    }
                else
                {
        @:กำลังยืม
    }
            </span>
        </div>
    </div>

    @if (!Model.IsReturn)
    {
        <div class="ds-warn-box">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 2L16.5 15H1.5L9 2Z" stroke="#854F0B" stroke-width="1.5" stroke-linejoin="round"/>
                <path d="M9 7V10" stroke="#854F0B" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="9" cy="13" r=".75" fill="#854F0B"/>
            </svg>
            <div>
                <p class="ds-warn-title">รายการนี้ยังไม่ได้คืน</p>
                <p class="ds-warn-desc">การลบจะทำให้ระบบจำนวนพร้อมใช้งานผิดพลาด ควรบันทึกคืนก่อนลบ</p>
            </div>
        </div>
    }

    <div class="ds-danger-box">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path d="M9 2L16.5 15H1.5L9 2Z" stroke="#A32D2D" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M9 7V10" stroke="#A32D2D" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="9" cy="13" r=".75" fill="#A32D2D"/>
        </svg>
        <div>
            <p class="ds-danger-title">การดำเนินการนี้ไม่สามารถย้อนกลับได้</p>
            <p class="ds-danger-desc">ประวัติการยืมนี้จะถูกลบออกจากระบบอย่างถาวร</p>
        </div>
    </div>

    <form asp-action="Delete">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id"/>
        <div class="ds-actions">
            <button type="submit" class="ds-btn-danger">ยืนยันการลบ</button>
            <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.ItemId"
               class="ds-btn-ghost">ยกเลิก / กลับรายการ</a>
        </div>
    </form>
</div>
