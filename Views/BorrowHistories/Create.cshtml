@model KlangIT_V3.ViewModels.BorrowCreateViewModel
@{
    ViewData["Title"] = "ทำการยืม";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")
@await Html.PartialAsync("~/Views/Shared/_ItemStateDiagram.cshtml")

<h1 class="ds-page-title">ทำการยืม</h1>

<div class="ds-page-layout">

    @* ── Left: State diagram ── *@
    <div>
        <div class="ds-diagram-wrap">
            <p class="ds-diagram-title">แผนผังการเปลี่ยนสถานะ</p>
            @await Html.PartialAsync("~/Views/Shared/_ItemStateDiagramSvgVertical.cshtml", "borrow")
        </div>
    </div>

    @* ── Right: Borrow form ── *@
    <div class="ds-card">
        <span class="ds-section-lbl">รายละเอียดการยืม</span>
        <form asp-action="Create">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

            <input type="hidden" asp-for="ItemId"/>

            <div class="ds-row">
                <label asp-for="ItemHeader" class="ds-lbl">ข้อมูลวัสดุ</label>
                <input asp-for="ItemHeader" class="ds-input ds-input-ro" readonly/>
            </div>

            <div class="ds-row">
                <label asp-for="ItemAssetId" class="ds-lbl">เลขทะเบียนทรัพย์สิน</label>
                <input asp-for="ItemAssetId" class="ds-input ds-input-ro" readonly
                       style="font-family:monospace;font-size:12px"/>
            </div>

            <div class="ds-row">
                <span class="ds-lbl">สถานะของวัสดุ</span>
                <div style="padding:8px 12px;background:var(--ds-bg2);border-radius:var(--ds-radius-md)">
                    @{
                        string statusBadge = Model.ItemStatus == KlangIT_V3.Models.Enums.ItemStatusEnum.Available
                            ? "ds-badge ds-badge-teal" : "ds-badge ds-badge-amber";
                    }
                    <span class="@statusBadge">@Html.DisplayFor(m => m.ItemStatus)</span>
                </div>
            </div>

            <div class="ds-row">
                <label asp-for="RequestUser" class="ds-lbl">ผู้ยืม</label>
                <input asp-for="RequestUser" class="ds-input"/>
                <span asp-validation-for="RequestUser" class="text-danger small"></span>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <label asp-for="SelectedDepartmentId" class="ds-lbl">ฝ่าย/กลุ่มงาน</label>
                    <select asp-for="SelectedDepartmentId" class="ds-select" asp-items="Model.Departments"></select>
                    <span asp-validation-for="SelectedDepartmentId" class="text-danger small"></span>
                </div>
                <div class="ds-row">
                    <label asp-for="SelectedSectionId" class="ds-lbl">หน่วยงาน</label>
                    <select asp-for="SelectedSectionId" class="ds-select" asp-items="Model.Sections"></select>
                    <span asp-validation-for="SelectedSectionId" class="text-danger small"></span>
                </div>
            </div>

            <div class="ds-row">
                <div class="ds-toggle-row">
                    <label class="ds-switch">
                        <input type="checkbox" asp-for="IsPermanentBorrow"/>
                        <span class="ds-slider"></span>
                    </label>
                    <span style="font-size:13px">ยืมถาวร (ไม่มีกำหนดคืน)</span>
                </div>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <label asp-for="BorrowDate" class="ds-lbl">วันที่ยืม</label>
                    <input asp-for="BorrowDate" class="ds-input" type="date"
                           value="@Model.BorrowDate.ToString("yyyy-MM-dd")"/>
                    <span asp-validation-for="BorrowDate" class="text-danger small"></span>
                </div>
                <div class="ds-row">
                    <label asp-for="ExpectedReturnDate" class="ds-lbl">กำหนดคืน</label>
                    <input asp-for="ExpectedReturnDate" class="ds-input" type="date"
                           value="@Model.ExpectedReturnDate?.ToString("yyyy-MM-dd")"/>
                </div>
            </div>

            <div class="ds-2col">
                <div class="ds-row">
                    <label asp-for="Itstaff" class="ds-lbl">ผู้ดำเนินการ (IT)</label>
                    <input asp-for="Itstaff" class="ds-input"/>
                    <span asp-validation-for="Itstaff" class="text-danger small"></span>
                </div>
                <div class="ds-row">
                    <label asp-for="Amount" class="ds-lbl">จำนวนที่ยืม</label>
                    <input asp-for="Amount" class="ds-input" type="number" min="1"/>
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>
            </div>

            <div class="ds-actions">
                <button type="submit" class="ds-btn-primary">บันทึกการยืม</button>
                <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.ItemId"
                   class="ds-btn-ghost">ยกเลิก</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
