@model KlangIT_V3.Models.BorrowHistory
@{
    ViewData["Title"] = "รายละเอียดการยืม";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<h1 class="ds-page-title">รายละเอียดการยืม</h1>

<div class="ds-card" style="max-width:580px;margin-bottom:1.25rem">
    <div class="ds-field-grid">
        <span class="ds-field-label">อุปกรณ์</span>
        <span class="ds-field-value">@Model.Item?.ItemType?.Name @Model.Item?.ItemBrand?.Name @Model.Item?.ItemModel?.Name</span>

        <span class="ds-field-label">เลขทะเบียน</span>
        <span class="ds-field-value" style="font-family:monospace;font-size:12px">@Model.Item?.AssetId</span>

        <span class="ds-field-label">ผู้ยืม</span>
        <span class="ds-field-value">@Model.BorrowerUser</span>

        <span class="ds-field-label">ฝ่าย/กลุ่มงาน</span>
        <span class="ds-field-value">@Model.BorrowerDepartment?.Name</span>

        <span class="ds-field-label">หน่วยงาน</span>
        <span class="ds-field-value">@Model.BorrowerSection?.Name</span>

        <span class="ds-field-label">ยืมถาวร</span>
        <span class="ds-field-value">@(Model.IsPermanentBorrow ? "ใช่" : "ไม่ใช่")</span>

        <span class="ds-field-label">วันที่ยืม</span>
        <span class="ds-field-value">@Model.BorrowDate.ToString("dd MMM yyyy HH:mm")</span>

        <span class="ds-field-label">กำหนดคืน</span>
        <span class="ds-field-value">@Model.DueDate?.ToString("dd MMM yyyy")</span>

        <span class="ds-field-label">สถานะ</span>
        <span class="ds-field-value">
            @if (Model.ReturnDate.HasValue)
            {
        @:คืนแล้ว
    }
            else
            {
        @:กำลังยืม
    }
        </span>

        <span class="ds-field-label">วันที่คืน</span>
        <span class="ds-field-value" style="font-weight:400;color:var(--ds-text2)">@(Model.ReturnDate?.ToString("dd MMM yyyy HH:mm") ?? "—")</span>

        <span class="ds-field-label">จำนวน</span>
        <span class="ds-field-value">@Model.Amount</span>

        <span class="ds-field-label">ผู้ดำเนินการ</span>
        <span class="ds-field-value">@(Model.ReturnDate.HasValue ? Model.ReturnItname : Model.BorrowItname)</span>
    </div>
</div>

<div class="ds-actions">
    @if (!Model.ReturnDate.HasValue)
    {
        <a asp-action="Return" asp-route-id="@Model.Id" class="ds-btn-primary">บันทึกคืน</a>
    }
    <a asp-action="Edit"   asp-route-id="@Model.Id" class="ds-btn-ghost">แก้ไข</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="ds-btn-del-ghost">ลบ</a>
    <a asp-action="Index"  class="ds-btn-ghost">กลับรายการ</a>
</div>
