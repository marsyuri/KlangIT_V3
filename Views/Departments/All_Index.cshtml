@model IEnumerable<KlangIT_V3.Models.Department>
@{
    ViewData["Title"] = "รายชื่อฝ่าย/กลุ่มงานทั้งหมด";
}
@await Html.PartialAsync("~/Views/Shared/_DesignSystem.cshtml")

<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:1.5rem">
    <div>
        <h1 class="ds-page-title" style="margin:0">รายชื่อฝ่าย/กลุ่มงานทั้งหมด</h1>
        <p class="ds-page-sub" style="margin:4px 0 0">รวมรายการที่ถูกลบแล้ว</p>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-action="Index" class="ds-btn-ghost">แสดงเฉพาะที่ใช้งาน</a>
        <a asp-action="Create" class="ds-btn-primary">+เพิ่มฝ่าย</a>
    </div>
</div>

<div class="ds-table-wrap">
    <table class="ds-table">
        <thead>
            <tr>
                <th style="width:48px">#</th>
                <th>ฝ่าย/กลุ่มงาน</th>
                <th>สถานะ</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="ds-table-empty">ไม่พบข้อมูล</td></tr>
            }
            else
            {
                int row = 0;
                foreach (var item in Model)
                {
                    row++;
                    <tr style="@(item.IsDeleted ? "opacity:0.55" : null)">
                        <td style="color:var(--ds-text3)">@row</td>
                        <td style="font-weight:500">@item.Name</td>
                        <td>
                            @if (item.IsDeleted)
                            {
        @:ถูกลบแล้ว
    }
                            else
                            {
        @:ใช้งาน
    }
                        </td>
                        <td>
                            @if (!item.IsDeleted)
                            {
                                <div class="ds-tbl-actions">
                                    <a asp-action="Edit"    asp-route-id="@item.Id" class="ds-btn-ghost ds-tbl-btn">แก้ไข</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="ds-btn-ghost ds-tbl-btn">รายละเอียด</a>
                                    <a asp-action="Delete"  asp-route-id="@item.Id" class="ds-btn-del-ghost ds-tbl-btn">ลบ</a>
                                </div>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
